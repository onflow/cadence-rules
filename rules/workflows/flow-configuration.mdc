## FCL Configuration

### Install FCL
```bash
npm install @onflow/fcl
# or
yarn add @onflow/fcl
```

### Basic FCL Setup

#### Configuration File
```typescript
// src/config/fcl-config.ts
import { config } from '@onflow/fcl';
import flowJSON from '../../flow.json';

// Network-specific configurations
const networkConfigs = {
  emulator: {
    'flow.network': 'emulator',
    'accessNode.api': 'http://127.0.0.1:8888',
    'discovery.wallet': 'http://localhost:8701/fcl/authn'
  },
  testnet: {
    'flow.network': 'testnet',
    'accessNode.api': 'https://rest-testnet.onflow.org',
    'discovery.wallet': 'https://fcl-discovery.onflow.org/testnet/authn'
  },
  mainnet: {
    'flow.network': 'mainnet',
    'accessNode.api': 'https://rest-mainnet.onflow.org',
    'discovery.wallet': 'https://fcl-discovery.onflow.org/authn'
  }
};

// Select network based on environment
const network = process.env.NEXT_PUBLIC_FLOW_NETWORK || 'testnet';
const networkConfig = networkConfigs[network];

// App metadata
const appConfig = {
  'app.detail.title': 'My Flow App',
  'app.detail.icon': 'https://myapp.com/icon.png',
  'app.detail.description': 'A Flow blockchain application',
  'app.detail.url': 'https://myapp.com'
};

// Initialize configuration
config({
  ...networkConfig,
  ...appConfig
}).load({ flowJSON });

export { config };
```

### React Integration

#### Wrap App with FlowProvider
```typescript
// src/App.tsx
import { FlowProvider } from '@onflow/react-sdk';
import './config/fcl-config';

function App() {
  return (
    <FlowProvider>
